generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  pending
  approved
  rejected
}

model User {
  id              String         @id @default(uuid())
  email           String         @unique
  passwordHash    String?
  displayName     String?
  googleId        String?
  status          UserStatus     @default(pending)
  xpTotal         Int            @default(0)
  streakDays      Int            @default(0)
  streakLastDate  DateTime?
  level           Int            @default(1)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  refreshTokens        RefreshToken[]
  userCards            UserCard[]
  userLessons          UserLesson[]
  conversations        Conversation[]
  passwordResetTokens  PasswordResetToken[]
  studySessions        StudySession[]

  @@map("users")
}

model RefreshToken {
  id         String   @id @default(uuid())
  userId     String
  tokenHash  String   @unique
  expiresAt  DateTime
  revoked    Boolean  @default(false)
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

enum Difficulty {
  beginner
  intermediate
  advanced
}

model Card {
  id          String        @id @default(uuid())
  word        String
  phonetic    String?
  meaning     String
  exampleFil  String?
  exampleEng  String?
  audioUrl    String?
  imageUrl    String?
  category    String
  difficulty  Difficulty
  unit        String?
  lessonSlug  String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  userCards   UserCard[]
  sessionCards SessionCard[]

  @@map("cards")
}

model UserCard {
  userId       String
  cardId       String
  easeFactor   Float    @default(2.5)
  interval     Int      @default(1)
  repetitions  Int      @default(0)
  nextReview   DateTime @default(now())
  lastReviewed DateTime?
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  card         Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@id([userId, cardId])
  @@map("user_cards")
}

model Lesson {
  id          String      @id @default(uuid())
  title       String
  slug        String      @unique
  contentJson Json
  orderIndex  Int
  difficulty  Difficulty
  unit        String?
  createdAt   DateTime    @default(now())
  userLessons UserLesson[]

  @@map("lessons")
}

model UserLesson {
  userId      String
  lessonId    String
  completedAt DateTime
  quizScore   Int
  xpAwarded   Int
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson      Lesson  @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@id([userId, lessonId])
  @@map("user_lessons")
}

model Conversation {
  id         String   @id @default(uuid())
  userId     String
  scenarioId String
  startedAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  turnCount  Int      @default(0)
  xpAwarded  Int      @default(0)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("conversations")
}

model TtsCache {
  id        String   @id @default(uuid())
  textHash  String   @unique
  audioUrl  String
  createdAt DateTime @default(now())

  @@map("tts_cache")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

model StudySession {
  id          String        @id @default(uuid())
  userId      String
  mode        String        @default("flashcard")
  category    String?
  cardCount   Int
  xpEarned    Int           @default(0)
  startedAt   DateTime      @default(now())
  completedAt DateTime?
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  cards       SessionCard[]

  @@map("study_sessions")
}

model SessionCard {
  id         String       @id @default(uuid())
  sessionId  String
  cardId     String
  rating     String
  reviewedAt DateTime     @default(now())
  session    StudySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  card       Card         @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@map("session_cards")
}

enum FocusType {
  actor
  object
  locative
  beneficiary
}

enum Aspect {
  infinitive
  completed
  incomplete
  contemplated
}

model Verb {
  id         String          @id
  root       String
  english    String
  category   String
  notes      String?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  focusTypes VerbFocusType[]

  @@map("verbs")
}

model VerbFocusType {
  id      String    @id @default(uuid())
  verbId  String
  type    FocusType
  affix   String
  verb    Verb      @relation(fields: [verbId], references: [id], onDelete: Cascade)
  forms   VerbForm[]

  @@unique([verbId, type])
  @@map("verb_focus_types")
}

model VerbForm {
  id          String        @id @default(uuid())
  focusTypeId String
  aspect      Aspect
  word        String
  focusType   VerbFocusType @relation(fields: [focusTypeId], references: [id], onDelete: Cascade)
  examples    VerbExample[]

  @@unique([focusTypeId, aspect])
  @@map("verb_forms")
}

model VerbExample {
  id      String   @id @default(uuid())
  formId  String
  tagalog String
  english String
  form    VerbForm @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@map("verb_examples")
}
